PORT=3000
ANTHROPIC_API_KEY=your_key_here
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_key
QURAN_API_BASE=https://api.quran.com/api/v4
NODE_ENV=development

# Optional — enables the semantic search (RAG) layer in
# semanticSearch.service.ts. Without this, the app runs fine on the
# curated emotion taxonomy alone (see emotionTaxonomy.ts).
# Get a key at https://dash.voyageai.com — Anthropic's recommended
# embeddings partner (Claude itself has no embeddings endpoint).
VOYAGE_API_KEY=your_voyage_key_here

# Optional — enables real (rather than sample) venues in
# activityProvider.service.ts's activity_suggestions. Without this, a
# hand-written sample catalog is used instead — the pipeline (scoring,
# blending, the checkin route) behaves identically either way.
# Get a key at https://console.cloud.google.com (enable the "Places API").
# Also enable the "Distance Matrix API" on the same project/key to get real
# current-traffic travel times on suggestions (optional on top of Places —
# suggestions still work without it, just without travel_time_minutes /
# traffic_delay_minutes).
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Optional — only needed to run scripts/seedDemoUsers.ts (creates 50 demo
# users for testing/demoing against a populated database). NEVER use this
# key in the mobile app or any client-facing code — it bypasses Row Level
# Security entirely. Find it in Supabase dashboard -> Project Settings ->
# API -> service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
